# ── About Section ────────────────────────────────────────
# Full project description / abstract text.

let about_p1 = "RustScript is a new programming language and compiler that lets you build web pages by writing HTML, CSS, and Python-style logic together in a single .rsx file. Built from scratch in Rust with zero dependencies, the compiler runs a complete pipeline — lexing, parsing, AST construction, and code generation — to output a self-contained HTML page with embedded CSS and JavaScript."

let about_p2 = "The language combines clean, Python-like syntax (variables, functions, recursion, loops, conditionals, lists, and string interpolation) with JSX-style UI markup for interface layout, plus inline styling powered by 60+ CSS shorthand properties. RustScript includes cross-file imports with circular dependency protection, a tree-walking interpreter for running scripts in the terminal, a built-in HTTP dev server with live reload, and a VS Code extension for syntax highlighting."

let about_p3 = "It's Turing-complete — shown through classic programs like recursion demos, FizzBuzz, and Fibonacci — and it's built around a simple idea: write one file, run one command, and get a working webpage with no frameworks, bundlers, or configuration."
