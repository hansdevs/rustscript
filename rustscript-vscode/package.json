{
  "name": "rustscript",
  "displayName": "RustScript",
  "description": "Syntax highlighting for the RustScript language (.rsx files)",
  "version": "0.1.1",
  "publisher": "Hansg123",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hansdevs/rustscript"
  },
  "contributes": {
    "languages": [
      {
        "id": "rustscript",
        "aliases": [
          "RustScript",
          "rsx"
        ],
        "extensions": [
          ".rsx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./file-icon.png",
          "dark": "./file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "rustscript",
        "scopeName": "source.rustscript",
        "path": "./syntaxes/rustscript.tmLanguage.json"
      }
    ]
  }
}
