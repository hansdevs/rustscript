{
  "name": "rustscript",
  "displayName": "RustScript",
  "description": "Syntax highlighting for the RustScript language (.rsx files)",
  "version": "0.1.0",
  "publisher": "rustscript",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "rustscript",
        "aliases": [
          "RustScript",
          "rsx"
        ],
        "extensions": [
          ".rsx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "rustscript",
        "scopeName": "source.rustscript",
        "path": "./syntaxes/rustscript.tmLanguage.json"
      }
    ]
  }
}
